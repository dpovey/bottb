# Pin the public npm registry for all packages, including the @types/* scope.
#
# Without this, Dependabot's environment was resolving public packages such as
# @types/node against https://npm.pkg.github.com (GitHub Packages), which only
# mirrors stale versions (e.g. @types/node 17.0.18), so every npm update job
# failed with ERR_PNPM_NO_MATCHING_VERSION and the dependabot PRs could not be
# rebased/merged. Explicitly pinning npmjs.org keeps resolution off GitHub
# Packages. This is the default registry, so it does not change normal installs.
registry=https://registry.npmjs.org/
@types:registry=https://registry.npmjs.org/
