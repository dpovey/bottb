{
  "name": "bottb",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.1.2",
  "sideEffects": [
    "*.css",
    "*.scss"
  ],
  "scripts": {
    "dev": "dotenv -e .env.local -- sh -c 'next dev -p ${PORT:-3030}'",
    "dev:restart": "dotenv -e .env.local -- sh -c 'PORT=${PORT:-3030}; lsof -ti:$PORT | xargs kill -9 2>/dev/null; rm -rf .next && next dev -p $PORT'",
    "build": "pnpm build:search-index && next build",
    "build:search-index": "dotenv -e .env.local -- tsx src/scripts/build-search-index.ts",
    "analyze": "next experimental-analyze",
    "analyze:ci": "next experimental-analyze --output",
    "lighthouse": "dotenv -e .env.local -- sh -c 'lighthouse http://localhost:${PORT:-3030} --output=json --output=html --output-path=./lighthouse-report --chrome-flags=\"--headless=new\" --preset=desktop'",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:coverage": "vitest --coverage",
    "test:ci": "vitest --run --coverage",
    "setup-db": "tsx src/scripts/setup-db.ts",
    "migrate": "dotenv -e .env.local -- node-pg-migrate -f migrate-config.json up",
    "migrate:create": "node-pg-migrate -f migrate-config.json create",
    "migrate:status": "dotenv -e .env.local -- node-pg-migrate -f migrate-config.json --dry-run up",
    "create-event": "tsx src/scripts/create-event.ts",
    "list-events": "tsx src/scripts/list-events.ts",
    "activate-event": "tsx src/scripts/activate-event.ts",
    "cleanup-event": "tsx src/scripts/cleanup-event.ts",
    "generate-votes": "tsx src/scripts/generate-votes.ts",
    "upload-band-logo": "tsx src/scripts/upload-band-logo.ts",
    "upload-event-image": "tsx src/scripts/upload-event-image.ts",
    "finalize-event": "tsx src/scripts/finalize-event.ts",
    "generate-scoring-sheet": "tsx src/scripts/generate-scoring-sheet.ts",
    "generate-qr-sheet": "tsx src/scripts/generate-qr-sheet.ts",
    "manage-users": "tsx src/scripts/manage-users.ts",
    "cleanup-temp-uploads": "tsx src/scripts/cleanup-temp-uploads.ts",
    "check-db-schema": "tsx src/scripts/check-db-schema.ts",
    "backup-db": "tsx src/scripts/backup-db.ts",
    "delete-all-photos": "tsx src/scripts/delete-all-photos.ts",
    "bulk-upload-photos": "tsx src/scripts/bulk-upload-photos.ts",
    "inspect-photo": "tsx src/scripts/inspect-photo-metadata.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "chromatic": "dotenv -e .env.local -- chromatic",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "capture-screenshots": "tsx src/scripts/capture-screenshots.ts",
    "e2e:docker:up": "docker compose -f docker-compose.test.yml up -d --wait",
    "e2e:docker:down": "docker compose -f docker-compose.test.yml down -v",
    "e2e:seed": "DATABASE_URL=postgres://test:test@localhost:5433/bottb_test tsx e2e/seed-test-db.ts",
    "e2e:dump": "docker compose -f docker-compose.test.yml exec -T postgres-test pg_dump -U test bottb_test > e2e/fixtures/test-db.sql",
    "e2e:restore": "docker compose -f docker-compose.test.yml exec -T postgres-test psql -U test -c 'DROP SCHEMA public CASCADE; CREATE SCHEMA public;' bottb_test && docker compose -f docker-compose.test.yml exec -T postgres-test psql -U test bottb_test < e2e/fixtures/test-db.sql",
    "e2e:smart-restore": "tsx e2e/smart-restore.ts",
    "e2e:test": "playwright test",
    "e2e": "pnpm e2e:docker:up && pnpm e2e:smart-restore && pnpm e2e:test",
    "seo:audit": "dotenv -e .env.local -- tsx src/scripts/seo-audit.ts",
    "schema:validate": "tsx src/scripts/validate-schema.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.10",
    "@fingerprintjs/fingerprintjs": "^5.1.0",
    "@orama/orama": "^3.1.18",
    "@posthog/nextjs-config": "^1.9.16",
    "@types/bcrypt": "^6.0.0",
    "@vercel/analytics": "^1.5.0",
    "@vercel/blob": "^2.0.0",
    "@vercel/postgres": "^0.10.0",
    "@vercel/speed-insights": "^1.3.1",
    "ai": "^6.0.26",
    "babel-plugin-react-compiler": "^1.0.0",
    "bcrypt": "^6.0.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "exifr": "^7.1.3",
    "facebook-nodejs-business-sdk": "^24.0.1",
    "fast-xml-parser": "^5.8.0",
    "framer-motion": "^12.23.26",
    "next": "16.2.6",
    "next-auth": "^5.0.0-beta.30",
    "posthog-js": "^1.376.0",
    "qrcode": "^1.5.4",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-easy-crop": "^5.5.6",
    "react-facebook-pixel": "^1.0.4",
    "resend": "^6.12.4",
    "sharp": "^0.33.5",
    "stripe": "^22.2.1",
    "swiper": "^12.1.3",
    "tailwind-merge": "^3.4.0",
    "uuid": "^14.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.60.0",
    "@storybook/addon-a11y": "10.2.10",
    "@storybook/addon-docs": "10.2.10",
    "@storybook/addon-onboarding": "10.2.10",
    "@storybook/addon-vitest": "10.2.10",
    "@storybook/nextjs-vite": "10.2.10",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.16.0",
    "@types/qrcode": "^1.5.5",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@types/uuid": "^11.0.0",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/browser": "^3.2.5",
    "@vitest/coverage-v8": "^3.2.4",
    "baseline-browser-mapping": "^2.9.14",
    "chromatic": "^13.3.4",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.17.0",
    "eslint-config-next": "^16.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-storybook": "10.2.10",
    "jsdom": "^29.0.1",
    "lighthouse": "^13.0.3",
    "msw": "^2.12.7",
    "node-mocks-http": "^1.17.2",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.13.0",
    "playwright": "^1.60.0",
    "postcss": "^8.5.10",
    "prettier": "^3.8.3",
    "storybook": "10.2.10",
    "structured-data-testing-tool": "^4.5.0",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.53.0",
    "undici": "^7.24.5",
    "vite": "^7.3.2",
    "vite-tsconfig-paths": "^6.0.2",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@posthog/cli",
      "bcrypt",
      "bufferutil",
      "core-js",
      "esbuild",
      "msw",
      "protobufjs",
      "sharp",
      "unrs-resolver"
    ],
    "overrides": {
      "@types/react": "19.2.15",
      "@types/react-dom": "19.2.3",
      "axios@<1.15.2": ">=1.15.2",
      "basic-ftp@<=5.3.0": ">=5.3.1",
      "brace-expansion@<1.1.13": ">=1.1.13",
      "brace-expansion@>=2.0.0 <2.0.3": ">=2.0.3",
      "brace-expansion@>=5.0.0 <5.0.6": ">=5.0.6",
      "@isaacs/brace-expansion@<=5.0.0": ">=5.0.1",
      "fast-uri@<=3.1.1": ">=3.1.2",
      "fast-xml-builder@<=1.1.6": ">=1.1.7",
      "flatted@<=3.4.1": ">=3.4.2",
      "follow-redirects@<=1.15.11": ">=1.16.0",
      "ip-address@<=10.1.0": ">=10.1.1",
      "lodash@<=4.17.23": ">=4.18.0",
      "lodash-es@<=4.17.23": ">=4.18.0",
      "minimatch@<3.1.4": ">=3.1.4",
      "minimatch@>=9.0.0 <9.0.7": ">=9.0.7",
      "minimatch@>=10.0.0 <10.2.3": ">=10.2.3",
      "nth-check@<2.0.1": ">=2.0.1",
      "path-to-regexp@<0.1.13": ">=0.1.13",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "postcss@<8.5.10": ">=8.5.10",
      "qs@<6.14.2": ">=6.14.2",
      "tmp@<=0.2.3": ">=0.2.4",
      "undici@<6.24.0": ">=6.24.0",
      "uuid@<11.1.1": ">=11.1.1",
      "validator@<13.15.22": ">=13.15.22",
      "ws@>=8.0.0 <8.20.1": ">=8.20.1"
    }
  }
}
